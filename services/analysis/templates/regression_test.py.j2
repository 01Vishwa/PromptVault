@pytest.mark.regression
def test_{{ task_name }}_{{ entry_id }}_rule_checks_pass(_task: Task) -> None:
    """Regression: rule judge must return passed=True with a live agent run.

    NOTE: This test requires the agent to be importable and runnable.
    Skip if no ANTHROPIC_API_KEY is set.
    """
    import os
    if not os.environ.get("ANTHROPIC_API_KEY"):
        pytest.skip("ANTHROPIC_API_KEY not set — skipping live agent regression.")

    import asyncio
    from agents.react import make_agent
    from harness.middleware import EvalHarness
    from harness.logger import EvalLogger
    import tempfile

    run_id = f"reg_{ENTRY_ID}"
    with tempfile.TemporaryDirectory() as tmp:
        with EvalLogger(run_id=run_id, output_dir=tmp) as logger:
            collector = TrajectoryCollector(run_id=run_id, task_id=TASK_ID)
            harness = EvalHarness(run_id=run_id, logger=logger, collector=collector)
            agent = make_agent()
            asyncio.run(
                agent.ainvoke(
                    {"input": _task.prompt},
                    config={"callbacks": [harness]},
                )
            )
    trajectory = collector.build("completed")
    result = run_rule_checks(_task, trajectory, collector._final_output)
    assert result.passed, (
        f"Regression test failed for {TASK_NAME!r}. "
        f"Failures: {result.failures}. Original annotation: {ANNOTATION_TAG!r}"
    )
