# =============================================================================
# AXIOM AI ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your API keys

# -----------------------------------------------------------------------------
# NVIDIA NIM (Primary LLM Provider)
# Get your key at: https://build.nvidia.com
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# -----------------------------------------------------------------------------
# GitHub Models (Fallback LLM Provider)
# Get your token at: https://github.com/settings/tokens
# Requires: GitHub Models access (free tier available)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_MODELS_URL=https://models.inference.ai.azure.com

# -----------------------------------------------------------------------------
# Tavily Search API (Web Search)
# Get your key at: https://tavily.com
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Agent Settings
MAX_REACT_ITERATIONS=5
MAX_TOOL_CALLS=10
DEFAULT_SEARCH_RESULTS=5
